{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // rootDir broadened to the repo root so step definitions can import the
    // wire protocol from packages/app/src/shared (DropZone, ZONE_*_RATIO).
    "rootDir": "../..",
    "noEmit": true,
    "jsx": "preserve",
    "types": ["node"]
  },
  "include": [
    "step_definitions/**/*.ts",
    "support/**/*.ts",
    "cucumber.js",
    "../app/src/shared/**/*.ts"
  ],
  // App unit tests (`*.test.ts`) import bun:test, which this package's
  // types ["node"] doesn't carry — they belong to `bun test` under
  // packages/app, not to the cucumber harness's typecheck.
  "exclude": ["../app/src/shared/**/*.test.ts"]
}
